Consulta.Endpoints=tcp -h localhost -p 10002 -t 60000

# Configuración del thread pool para manejar múltiples consultas
Ice.ThreadPool.Server.Size=10
Ice.ThreadPool.Server.SizeMax=50
Ice.ThreadPool.Client.Size=5
Ice.ThreadPool.Client.SizeMax=25

# Configuración de timeout y retry
Ice.Default.Timeout=10000
Ice.RetryIntervals=0 1000 3000

# Configuración de ACM para mantener las conexiones vivas
Ice.ACM.Client=0
Ice.ACM.Server=0 